# Artefactos regenerables (ver README del caso 1)
reports/*
!reports/.gitkeep

# Scrapes competitivos: por defecto no subir corridas intermedias.
# Excepción: `scrape_latest.csv` versionado como artefacto de entrega del caso 2.
data/caso_2_competitive_intelligence/output/*
!data/caso_2_competitive_intelligence/output/.gitkeep
!data/caso_2_competitive_intelligence/output/scrape_latest.csv

