# Entorno y secretos
.venv/
.env
.env.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/

# Artefactos regenerables (ver README: python -m operaciones.generate_report)
reports/*
!reports/.gitkeep

# Scrapes competitivos (CSV/JSON generados; no commitear corridas reales)
data/competitive_intelligence/output/*
!data/competitive_intelligence/output/.gitkeep

# IDE / OS
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db
