# Copia este archivo a .env y rellena (no subas .env a git)
OPENAI_API_KEY=

# --- Caso 2: Playwright (opcional) ---
# Navegador por defecto en código: firefox. Override: chromium | firefox | webkit
# PLAYWRIGHT_BROWSER=chromium
# Depurar DiDi (logs en stderr: URL, título, extracto de texto): CI_SCRAPER_DEBUG=1
# DiDi web suele exigir login. Tras `python -m competitive_intel save-didi-session` (desde caso_2_...):
# PLAYWRIGHT_STORAGE_STATE=didi_storage_state.json

# --- Caso 2: scrape Uber desde fuera de México (opcional) ---
# Si Uber muestra "We're coming soon", prueba VPN en México o proxy:
# PLAYWRIGHT_PROXY=http://127.0.0.1:8888
# Geolocalización: por defecto el scrape concede ubicación CDMX (DiDi y otras la piden).
# Solo si quieres desactivarla:
# CI_SCRAPER_NO_GEOLOCATION=1
# Forzar una URL tras probarla a mano en Chrome:
# UBER_EATS_URL=https://www.ubereats.com/mx/

# --- Caso 2: rate limit (Rappi / Uber: JSON bd.error.too_many_requests en la página) ---
# Sube `--delay` (p.ej. 6–10) y/o pausa entre bloques: el código reintenta con backoff en Uber y Rappi.
# CI_SCRAPER_PLATFORM_GAP_SEC=45
# Uber: por defecto se limpian cookies del contexto antes de cada dirección (solo plataforma uber_eats).
# Desactivar: CI_SCRAPER_NO_UBER_COOKIE_CLEAR=1
# Rappi: mismo patrón (reduce degradación entre ciudades). Desactivar: CI_SCRAPER_NO_RAPPI_COOKIE_CLEAR=1
